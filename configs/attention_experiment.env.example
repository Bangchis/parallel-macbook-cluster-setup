# Copy to configs/attention_experiment.env and edit on the master VM.
# This file controls the final required self-attention experiments.

# Cluster execution.
export ATTN_USE_HOSTFILE=1
export ATTN_HOSTFILE=configs/hosts
export MPI_LAN_CIDR=192.168.31.0/24

# Use the total number of physical CPU cores across the 3 MacBooks.
# Example: 3 machines x 4 physical cores = 12 MPI processes.
export ATTN_TOTAL_PROCS=12
export ATTN_P_LIST="1 2 4 8 12"

# Per-rank OpenMP threads. Keep 1 for the required "processes = cores" tests.
export ATTN_THREADS=1

# Attention problem shape.
export ATTN_B=1
export ATTN_H=8
export ATTN_DH=64
export ATTN_CAUSAL=0

# Main algorithm and mapping.
export ATTN_ALGO=mpi_online
export ATTN_ASSIGNMENT=block_cyclic
export ATTN_BR=32
export ATTN_BC=64
export ATTN_SCHEDULE=static

# Find-N stage.
# Expand this list if none of the values reaches 2-3 minutes.
export ATTN_FIND_N_LIST="512 1024 1536 2048 3072 4096"
export ATTN_TARGET_MIN_MS=120000
export ATTN_TARGET_MAX_MS=180000

# Optional manual override after you inspect results/raw/find_N.csv.
# Leave empty to auto-select the closest L.
export ATTN_SELECTED_N=

# Granularity and block-size sweeps.
export ATTN_ASSIGNMENT_LIST="contiguous cyclic block_cyclic"
export ATTN_BR_LIST="1 8 16 32 64"
export ATTN_BC_LIST="32 64 128 256"

# Repeat each timing to reduce noise. Increase to 3 only if time allows.
export ATTN_REPEAT=1
