# Copy this file to configs/cluster.env, then replace every value.

MASTER_IP=192.168.1.10
NODE1_IP=192.168.1.11
NODE2_IP=192.168.1.12

# Optional. Leave empty to infer /24 from MASTER_IP.
LAN_SUBNET=

MASTER_PUBLIC_KEY='ssh-ed25519 REPLACE_WITH_MASTER_PUBLIC_KEY master'
NODE1_PUBLIC_KEY='ssh-ed25519 REPLACE_WITH_NODE1_PUBLIC_KEY node1'
NODE2_PUBLIC_KEY='ssh-ed25519 REPLACE_WITH_NODE2_PUBLIC_KEY node2'

CLUSTER_USER=mpot
MASTER_USER=mpot
NODE1_USER=mpot
NODE2_USER=mpot
SLOTS_PER_NODE=4
